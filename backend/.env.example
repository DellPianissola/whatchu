# Banco de dados
# Para dev local (fora do Docker). No Docker, o compose constrói isso de DB_USER/DB_PASSWORD/DB_NAME.
DATABASE_URL=postgresql://whatchu:troque_em_producao@localhost:5432/whatchu

# Servidor
PORT=5000
NODE_ENV=development

# APIs externas
TMDB_API_KEY=sua_chave_aqui         # https://www.themoviedb.org/settings/api

# JWT — usar secrets longos e aleatórios em produção (nunca reutilizar entre si)
JWT_SECRET=troque_por_um_secret_longo_e_aleatorio
REFRESH_TOKEN_SECRET=troque_por_outro_secret_longo_e_aleatorio

# CORS — origem permitida em produção (em dev deixar vazio, aceita qualquer origem)
CORS_ORIGIN=https://seudominio.com

# Admin inicial (criado automaticamente ao subir o Docker, idempotente)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque_em_producao
ADMIN_EMAIL=admin@seudominio.com

# Email transacional (Resend — https://resend.com)
RESEND_API_KEY=re_sua_chave_aqui
EMAIL_FROM=Whatchu <noreply@seudominio.com>
APP_URL=https://seudominio.com          # URL base do frontend (usado nos links dos emails)
TEST_EMAIL_TO=seu@email.com

# MinIO — armazenamento de imagens
MINIO_ENDPOINT_HOST=minio              # hostname interno Docker; em dev: localhost
MINIO_PORT=9000
MINIO_USE_SSL=false                    # true em produção com HTTPS
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=troque_em_producao
MINIO_BUCKET=whatchu
MINIO_PUBLIC_URL=http://localhost:9000  # URL acessível pelo browser (pode ser domínio público)
