{
  "name": "whatchu-backend",
  "version": "0.2.1-alpha",
  "description": "Backend API para Whatchu",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:integration:coverage": "vitest run --config vitest.integration.config.js --coverage",
    "test:all": "npm test && npm run test:integration",
    "test:manual": "vitest run --config vitest.manual.config.js",
    "test:db": "docker compose --profile test up postgres-test -d"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "resend": "^6.12.2",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1",
    "vitest": "^4.1.5"
  }
}
