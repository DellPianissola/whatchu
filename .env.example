# Banco de dados (usado pelo docker-compose)
DB_USER=whatchu
DB_PASSWORD=troque_em_producao
DB_NAME=whatchu
DB_HOST=postgres    # hostname interno Docker; em dev local: localhost
DB_PORT=5432
DB_PORT_TEST=5433

# Portas expostas pelo Docker no host
# Dev local: FRONTEND_PORT=3000 (Vite). Produção: FRONTEND_PORT=8080 (Caddy/nginx ocupa 80)
FRONTEND_PORT=3000
BACKEND_PORT=5000

# Frontend — URL pública do backend (injetada em build time pelo Vite)
# Dev:       http://localhost:5000/api
# Produção:  /api  (path relativo — nginx do frontend faz proxy pro backend)
VITE_API_URL=/api
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_AMAZON_TAG=your-amazon-affiliate-tag
VITE_PORTFOLIO_URL=https://your-portfolio-url

# MinIO — credenciais do serviço (usadas pelo docker-compose)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=troque_em_producao_min_8_chars
MINIO_BUCKET=whatchu
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Testes — JWT isolado pra não vazar o secret de produção nos logs do compose
JWT_SECRET_TEST=docker-test-secret-nao-usar-em-producao
