// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  password      String
  birthDate     DateTime?
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  profile              Profile?
  verificationTokens   VerificationToken[]

  @@map("users")
}

// Cadastro pendente — vive até o usuário verificar o email (clicar no link).
// Não é um User real ainda: não pode fazer login nem reset de senha.
// Quando verifica, vira User e este registro é deletado.
// Cleanup automático: registros com expiresAt < now() podem ser removidos por cron.
model PendingRegistration {
  id        String   @id @default(uuid())
  email     String
  username  String
  password  String   // hash bcrypt
  birthDate DateTime?
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("pending_registrations")
}

model Profile {
  id                String    @id @default(uuid())
  name              String
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  onboardedAt       DateTime?
  avatarUrl         String?
  allowAdultContent Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relacionamentos
  movies    Movie[]

  @@map("profiles")
}

model Movie {
  id          String   @id @default(uuid())
  title       String
  type        MovieType
  description String?
  poster      String?
  year        Int?
  duration    Int?     // Duração em minutos (filmes) ou episódios (séries)
  genres      String[] // Array de gêneros
  rating      Decimal? @db.Decimal(3, 1) // Nota de 0 a 10
  priority    Priority @default(MEDIUM)
  isNew       Boolean  @default(false)
  watched     Boolean  @default(false)
  watchedAt   DateTime?
  externalId  String?  // ID da API externa (TMDB, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relacionamentos
  addedById   String
  addedBy     Profile  @relation(fields: [addedById], references: [id], onDelete: Cascade)
  addedAt     DateTime @default(now())
  
  @@index([addedById])
  @@index([type])
  @@index([priority])
  @@index([watched])
  @@map("movies")
}

model VerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("verification_tokens")
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum MovieType {
  MOVIE
  SERIES
  ANIME
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

